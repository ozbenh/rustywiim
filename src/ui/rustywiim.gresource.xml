<?xml version="1.0" encoding="UTF-8"?>
<gresources>
  <gresource prefix="/io/github/ozbenh/rustywiim/icons/scalable/apps">
    <file alias="io.github.ozbenh.rustywiim.svg">icons/rustywiim-icon.svg</file>
    <file alias="rustywiim-rca-inout.svg">icons/rca-inout.svg</file>
    <file alias="rustywiim-jack-inout.svg">icons/jack-inout.svg</file>
    <file alias="rustywiim-optical-inout.svg">icons/optical-inout.svg</file>
    <file alias="rustywiim-coax-inout.svg">icons/coax-inout.svg</file>
    <file alias="rustywiim-hdmi-inout.svg">icons/hdmi-inout.svg</file>
    <file alias="rustywiim-audio-output.svg">icons/audio-output.svg</file>
    <file alias="rustywiim-remote.svg">icons/wiim-remote.svg</file>
    <!-- Streaming-service brand marks — genuine "-symbolic" icons, same
         mechanism as the enter/exit-kiosk icons below: each SVG's paths
         use the "#2e3436" recolor-placeholder fill (GNOME/Adwaita's
         standard "regular foreground" convention), and the "-symbolic"
         suffix on the alias name is what makes GTK treat the icon as
         recolorable at all — that check is purely name-based for a
         GResource-backed custom icon theme, no `index.theme` involved.
         Looked up as a plain icon-name string and displayed via
         `gtk::Image`'s `icon-name` property. Path data for the plain
         (non-Illustrator-export) marks is the pristine simple-icons project
         source (github.com/simple-icons/simple-icons, CC0-1.0) -->
    <file alias="rustywiim-svc-spotify-symbolic.svg">icons/svc-spotify.svg</file>
    <file alias="rustywiim-svc-tidal-symbolic.svg">icons/svc-tidal.svg</file>
    <file alias="rustywiim-svc-qobuz-symbolic.svg">icons/svc-qobuz.svg</file>
    <file alias="rustywiim-svc-deezer-symbolic.svg">icons/svc-deezer.svg</file>
    <file alias="rustywiim-svc-pandora-symbolic.svg">icons/svc-pandora.svg</file>
    <file alias="rustywiim-svc-napster-symbolic.svg">icons/svc-napster.svg</file>
    <file alias="rustywiim-svc-iheartradio-symbolic.svg">icons/svc-iheartradio.svg</file>
    <file alias="rustywiim-svc-tunein-symbolic.svg">icons/svc-tunein.svg</file>
    <file alias="rustywiim-svc-amazon-symbolic.svg">icons/svc-amazon.svg</file>
    <!-- Quality-tier badge icons — same icon-vs-text-pill pattern as the
         service brand marks above, but keyed by the translated quality
         label instead of the service name (see IconSet::quality_paintable()).
         Unlike the brand marks, this is the real certification logo's own
         colors (gold/bronze gradient), not a baked flat fill. -->
    <file alias="rustywiim-hires-audio-logo.svg">icons/hires-audio-logo.svg</file>
    <!-- These two are genuine "-symbolic" icons -->
    <file alias="rustywiim-enter-kiosk-symbolic.svg">icons/enter-kiosk.svg</file>
    <file alias="rustywiim-exit-kiosk-symbolic.svg">icons/exit-kiosk.svg</file>
    <!-- EQ editor button — svgrepo.com source ("equalizer" mark),
         recolored to the "#2e3436" symbolic placeholder fill, same
         convention as every other icon above. License terms for this
         specific asset not independently re-verified here — check
         svgrepo.com's own page for it before any redistribution concern
         comes up. -->
    <file alias="rustywiim-equalizer-symbolic.svg">icons/equalizer.svg</file>
  </gresource>
  <!-- RustyWiiM Wood theme's background/panel textures — referenced from
       themes/wood/wood.css as url("resource:///io/github/ozbenh/rustywiim/
       themes/wood/..."), not include_bytes!'d directly (unlike the CSS
       files themselves): CSS background-image needs a GIO-resolvable URI,
       and this same GResource bundle is already registered process-wide by
       init_icon_resource() before any theme CSS loads (see that function's
       doc comment). Both are procedurally-generated SVGs (an feTurbulence
       filter, not a bitmap, rasterized live by librsvg at whatever size GTK
       requests, so there's no fixed-resolution tiling seam the way a bitmap
       texture would have. No other theme has assets here yet. -->
  <gresource prefix="/io/github/ozbenh/rustywiim/themes/wood">
    <file alias="wood-grain.svg">themes/wood/wood-grain.svg</file>
    <file alias="wood-panel.svg">themes/wood/wood-panel.svg</file>
  </gresource>
</gresources>
