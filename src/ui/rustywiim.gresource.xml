    <!-- Streaming-service brand marks — plain custom icons (fixed opaque
         white fill baked into each SVG), not "-symbolic": a symbolic-
         suffixed custom icon looked up manually and applied via a plain
         `gtk::Image::set_paintable()` rendered blank in testing (unlike
         `gtk::Image::set_from_icon_name()`, which manages its own
         style-context-driven recoloring). See svc-spotify.svg's own
         comment for sourcing/attribution. -->
    <file alias="rustywiim-svc-spotify.svg">icons/svc-spotify.svg</file>
    <file alias="rustywiim-svc-tidal.svg">icons/svc-tidal.svg</file>
    <file alias="rustywiim-svc-qobuz.svg">icons/svc-qobuz.svg</file>
